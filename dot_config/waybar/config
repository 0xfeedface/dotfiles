// vim:ft=jsonc
{
    "layer": "top",
    "reload_style_on_change": true,
    "modules-left": [
        "niri/workspaces"
    ],
    // "modules-center": [
    // ],
    "modules-right": [
        "idle_inhibitor",
        // "network",
        "memory",
        "cpu",
        "battery",
        "temperature",
        "clock",
        "tray"

        // "keyboard-state",
    ],
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },
    "memory": {
        "interval": 3,
        "format": "{}\u2009% ",
        "max-length": 10
    },
    "cpu": {
        "interval": 3,
        "format": "{}\u2009% ",
        "max-length": 10
    },
    "network": {
        "interval": 10,
        "format": "{ifname}",
        "format-wifi": "{ipaddr} ({signalStrength}\u2009%) ",
        "format-ethernet": "{ipaddr} ",
        // An empty format will hide the module.
        "format-disconnected": "no link",
        "max-length": 50,
        "family": "ipv4"
    },
    "battery": {
        "format": "{capacity}\u2009% {icon}",
        "format-icons": ["", "", "", "", ""]
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}\u2009°C {icon}",
        "format-icons": ["", "", ""],
        "tooltip": false
    },
    "clock": {
        "interval": 30,
        "format": "{:%Y-%m-%d %H:%M}",
        "format-alt": "{:%H:%M}",
        "tooltip-format": "{:%a, %Y-%m-%d %H:%M}"
    },
    "tray": {
        "spacing": 10
    }
}
